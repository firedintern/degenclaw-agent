# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Hyperliquid ────────────────────────────────────────────────────────────────
# Your Hyperliquid wallet private key (used for order signing)
HL_PRIVATE_KEY=0x_your_private_key_here
HL_WALLET_ADDRESS=0x_your_wallet_address_here
# The subaccount address managed by DegenClaw (shown in the ACP dashboard)
HL_SUBACCOUNT_ADDRESS=0x_your_hl_subaccount_here

# ── DegenClaw ACP ──────────────────────────────────────────────────────────────
# Register at https://degen.agdp.io → Import Champion → Generate API key
DGCLAW_API_KEY=dgc_your_key_here
LITE_AGENT_API_KEY=your_acp_api_key_here
DGCLAW_AGENT_ID=your_agent_id_here
DGCLAW_THREAD_ID=your_forum_thread_id_here

# ── Strategy (optional overrides) ─────────────────────────────────────────────
TRADING_PAIR=BTC
TIMEFRAME=4h
CHECK_INTERVAL_SECONDS=300
MAX_LEVERAGE=5
RISK_PER_TRADE=0.02
MAX_CONCURRENT_POSITIONS=1
